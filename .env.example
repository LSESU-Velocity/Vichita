# Eve / model routing
EVE_MODEL=zai/glm-5.2
# Optional comma-separated fallback models. Keep these on the same provider as
# EVE_MODEL unless agent/agent.ts is changed to use an explicit gateway model.
EVE_MODEL_FALLBACKS=

# Optional current-year large/flagship event deadlines from SU guidance.
# Leave blank unless manually verified for the academic year.
LSESU_TERM1_LARGE_EVENT_DEADLINE=
LSESU_TERM2_LARGE_EVENT_DEADLINE=
AI_GATEWAY_API_KEY=

# Vercel Connect Slack connector UID
SLACK_CONNECTOR=

# Google Workspace
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_TEMPLATE_RISK_ASSESSMENT_FILE_ID=
GOOGLE_TEMPLATE_BUDGET_FILE_ID=
GOOGLE_TEMPLATE_SPONSORSHIP_CONTRACT_FILE_ID=
GOOGLE_TRACKERS_SPREADSHEET_ID=

# Rules/source registry
RULES_SOURCE_SET_ID=
RULES_LAST_VERIFIED_DATE=

# Scheduled reminder route
CRON_SECRET=
DEFAULT_TIMEZONE=Europe/London

# App
APP_BASE_URL=
VICHITA_ENV=development
